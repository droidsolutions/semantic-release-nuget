<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--To inherit the global NuGet package sources remove the <clear/> line below -->
    <clear />
    <add key="nuget" value="https://api.nuget.org/v3/index.json" />
    <add key="gitlab-droidsolutions" value="https://gitlab.droidnet.de/api/v4/groups/4/-/packages/nuget/index.json" />
    <add key="gitlab-droid-platform" value="https://gitlab.droidnet.de/api/v4/groups/642/-/packages/nuget/index.json" />
    <add key="test with space" value="https://nuget.contoso.com/v3/index.json" />
    <add key="test-without-space" value="https://nuget.contoso.com/v3/index.json" />
  </packageSources>
  <disabledPackageSources>
    <add key="test with space" value="true" />
    <add key="test-without-space" value="true" />
  </disabledPackageSources>
</configuration>
